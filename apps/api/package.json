    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.10.0",
    "node-forge": "^1.3.1",
    "playwright": "^1.50.1",
    "puppeteer": "^24.2.1",
    "resend": "^4.1.2",
    "stripe": "^17.6.0",
    "winston": "^3.17.0",
    "xadesjs": "^2.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@medicore/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.10",
