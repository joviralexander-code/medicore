{
  "extends": "@medicore/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "Node16",
    "moduleResolution": "node16",
    "verbatimModuleSyntax": false,
    "lib": ["ES2022", "DOM"],
    "declaration": false,
    "declarationMap": false,
    "composite": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
