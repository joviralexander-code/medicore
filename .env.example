# ============================================================
# MediCore Ecuador — Variables de entorno
# Copia este archivo como .env en cada app que lo necesite
# ============================================================

# ----------------------
# Supabase
# ----------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SOLO backend/API — NUNCA en apps/web

# ----------------------
# App URLs
# ----------------------
NEXT_PUBLIC_ROOT_DOMAIN=medicore.ec
NEXT_PUBLIC_APP_URL=https://medicore.ec
NEXT_PUBLIC_API_URL=https://api.medicore.ec
API_PORT=3001

# ----------------------
# Redis
# ----------------------
REDIS_URL=redis://localhost:6379

# ----------------------
# SRI Ecuador
# ----------------------
SRI_CERT_ENCRYPTION_KEY=32-byte-hex-key-aqui   # AES-256-CBC para cifrar p12
SRI_AMBIENTE_DEFAULT=1                           # 1=pruebas, 2=produccion

# ----------------------
# Pagos
# ----------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_CLINICA=price_...
STRIPE_PRICE_ENTERPRISE=price_...

PAYPHONE_TOKEN=...
PAYPHONE_STORE_ID=...

# ----------------------
# Claude AI (Anthropic)
# ----------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------
# Email (Resend)
# ----------------------
RESEND_API_KEY=re_...
RESEND_FROM=noreply@medicore.ec

# ----------------------
# Meta (Facebook/Instagram)
# ----------------------
META_APP_ID=...
META_APP_SECRET=...
META_WEBHOOK_VERIFY_TOKEN=...

# ----------------------
# TikTok
# ----------------------
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...

# ----------------------
# LinkedIn
# ----------------------
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...

# ----------------------
# WhatsApp Business API
# ----------------------
WHATSAPP_BUSINESS_ACCOUNT_ID=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_ACCESS_TOKEN=...
WHATSAPP_WEBHOOK_VERIFY_TOKEN=...

# ----------------------
# Cifrado master (P12 y tokens)
# ----------------------
P12_MASTER_KEY=...   # Clave AES-256 para cifrar certificados SRI
TOKEN_ENCRYPTION_KEY=...  # Para tokens de redes sociales
